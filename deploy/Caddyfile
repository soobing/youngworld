# =====================================================================
# Caddyfile — 영월드 리버스 프록시 (자동 HTTPS)
# youngworld.example.com 을 실제 도메인으로 바꾸세요.
# Caddy 가 Let's Encrypt 인증서를 자동 발급/갱신하고,
# 443(HTTPS)·80(→443 리다이렉트)을 받아 내부 Node(127.0.0.1:3000)로 넘깁니다.
# WebSocket(Socket.io)도 별도 설정 없이 자동 프록시됩니다.
# =====================================================================

youngworld.example.com {
	encode gzip
	reverse_proxy 127.0.0.1:3000
}
